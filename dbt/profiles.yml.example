# Copy to profiles.yml for local (non-Docker) dbt runs. profiles.yml is gitignored.
# Never commit real credentials: use SOPS + AGE for anything deployed.
andvari:
  target: dev
  outputs:
    dev:
      type: postgres
      host: 127.0.0.1
      port: 5432
      user: andvari_admin
      password: CHANGE_ME_local_only
      dbname: andvari
      schema: public
      threads: 4

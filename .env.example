# =============================================================================
# Andvari (LLM Telemetry): environment
# Copy to .env and set real values. NEVER commit .env.
# These are LOCAL DEV values only. For anything deployed, use SOPS + AGE.
# =============================================================================

# Postgres owner: runs migrations, dbt, and the data loaders
DB_USER=andvari_admin
DB_PASSWORD=CHANGE_ME_local_only
DB_NAME=andvari

# Read-only role the app connects as (SELECT on mart/analytics only)
READER_DB_USER=portfolio_reader
READER_DB_PASSWORD=CHANGE_ME_local_only

# Bind Postgres to loopback only. Never expose 0.0.0.0 on a public host.
POSTGRES_EXPOSE_PORT=127.0.0.1:55432

# Where the app is mounted. Empty means the root, which is what you want when
# running it standalone. Behind a reverse proxy set the path segment, e.g.
# APP_BASE_PATH=forecaster to serve at /forecaster/.
APP_BASE_PATH=
